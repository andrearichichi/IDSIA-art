<?xml version="1.0"?>
<robot name="foldchair_102255">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
  <link name="moving_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0.012001708 -0.0079950423" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/moving_link.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0.012001708 -0.0079950423" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/moving_link.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
  <joint name="foldchair_102255_joint" type="revolute">
    <parent link="base_link"/>
    <child link="moving_link"/>
    <origin xyz="0 -0.012001708 0.0079950423" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.3962634016" upper="0" effort="100" velocity="10"/>
  </joint>
