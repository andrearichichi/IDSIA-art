<?xml version="1.0"?>
<robot name="blade_103706">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/blade_103706_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/blade_103706_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.018945767 0.025636025 0.025158954" rpy="0 0 0"/>
      <mass value="0.068419596"/>
      <inertia ixx="0.019922337" ixy="0.000000000" ixz="0.000000000" iyy="0.000627694" iyz="0.000000000" izz="0.020243657"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/blade_103706_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/blade_103706_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.004990726 0.071343290 0.073423035" rpy="0 0 0"/>
      <mass value="0.031580404"/>
      <inertia ixx="0.005660239" ixy="0.000000000" ixz="0.000000000" iyy="0.000075112" iyz="0.000000000" izz="0.005677428"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="0.000000000 0.000000000 0.000000000" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="0.000000000 -1.000000000 0.000000000"/>
    <limit lower="0.000000000" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
