<?xml version="1.0"?>
<robot name="stapler_103111">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/stapler_103111_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/stapler_103111_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.000676361 0.000125240 -0.056217371" rpy="0 0 0"/>
      <mass value="0.032138561"/>
      <inertia ixx="0.010057376" ixy="0.000000000" ixz="0.000000000" iyy="0.001535060" iyz="0.000000000" izz="0.010379241"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/stapler_103111_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/stapler_103111_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.004815523 -1.056943607 0.264820421" rpy="0 0 0"/>
      <mass value="0.067861439"/>
      <inertia ixx="0.019001247" ixy="0.000000000" ixz="0.000000000" iyy="0.001150034" iyz="0.000000000" izz="0.018200576"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="0.000000000 0.752066445 0.105008706" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="1.000000000 0.000000000 0.000000000"/>
    <limit lower="-0.698131701" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
