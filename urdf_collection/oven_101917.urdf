<?xml version="1.0"?>
<robot name="oven_101917">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/oven_101917_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/oven_101917_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.005314692 -0.186135499 0.458536970" rpy="0 0 0"/>
      <mass value="0.099325969"/>
      <inertia ixx="0.025124698" ixy="0.000000000" ixz="0.000000000" iyy="0.030128815" iyz="0.000000000" izz="0.022260013"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/oven_101917_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/oven_101917_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.639322077 -0.308659247 0.374388738" rpy="0 0 0"/>
      <mass value="0.000674031"/>
      <inertia ixx="0.000042571" ixy="0.000000000" ixz="0.000000000" iyy="0.000118059" iyz="0.000000000" izz="0.000109434"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="-0.638236000 -0.419428015 -0.442321324" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="1.000000000 0.000000000 0.000000000"/>
    <limit lower="0.000000000" upper="0.523598776" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
