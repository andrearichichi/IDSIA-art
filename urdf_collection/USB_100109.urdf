<?xml version="1.0"?>
<robot name="USB_100109">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/USB_100109_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/USB_100109_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.232902503 -0.150671509 0.010658187" rpy="0 0 0"/>
      <mass value="0.034318766"/>
      <inertia ixx="0.007445256" ixy="0.000000000" ixz="0.000000000" iyy="0.000877825" iyz="0.000000000" izz="0.007989252"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/USB_100109_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/USB_100109_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.380505395 -0.390387960 0.037236002" rpy="0 0 0"/>
      <mass value="0.065681234"/>
      <inertia ixx="0.008619782" ixy="0.000000000" ixz="0.000000000" iyy="0.008609106" iyz="0.000000000" izz="0.015714171"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="-0.240558504 0.387080368 0.000000000" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="0.000000000 0.000000000 1.000000000"/>
    <limit lower="-0.785398163" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
