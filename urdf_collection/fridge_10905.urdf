<?xml version="1.0"?>
<robot name="fridge_10905">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/fridge_10905_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/fridge_10905_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.208745888 0.060478890 0.337681070" rpy="0 0 0"/>
      <mass value="0.079071207"/>
      <inertia ixx="0.008986122" ixy="0.000000000" ixz="0.000000000" iyy="0.009418131" iyz="0.000000000" izz="0.006990863"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/fridge_10905_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/fridge_10905_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.031502286 -0.347278698 -0.420059775" rpy="0 0 0"/>
      <mass value="0.020928793"/>
      <inertia ixx="0.002041749" ixy="0.000000000" ixz="0.000000000" iyy="0.001456835" iyz="0.000000000" izz="0.001169028"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="0.226917667 -0.166912436 0.456948000" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="0.000000000 0.000000000 1.000000000"/>
    <limit lower="-1.047197551" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
