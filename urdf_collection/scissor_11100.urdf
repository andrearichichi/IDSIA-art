<?xml version="1.0"?>
<robot name="scissor_11100">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/scissor_11100_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/scissor_11100_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.221462642 0.131165568 -0.009076123" rpy="0 0 0"/>
      <mass value="0.055479452"/>
      <inertia ixx="0.008045061" ixy="0.000000000" ixz="0.000000000" iyy="0.008694374" iyz="0.000000000" izz="0.016612930"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/scissor_11100_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/scissor_11100_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.112864997 -0.156619577 -0.014202970" rpy="0 0 0"/>
      <mass value="0.044520548"/>
      <inertia ixx="0.006258346" ixy="0.000000000" ixz="0.000000000" iyy="0.007173916" iyz="0.000000000" izz="0.013330745"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="-0.309408835 0.000619823 0.021692000" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="0.000000000 0.000000000 1.000000000"/>
    <limit lower="0.000000000" upper="0.698131701" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
