<?xml version="1.0"?>
<robot name="foldchair_102255">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/foldchair_102255_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/foldchair_102255_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.015693960 0.143473919 0.358712350" rpy="0 0 0"/>
      <mass value="0.067129136"/>
      <inertia ixx="0.018407480" ixy="0.000000000" ixz="0.000000000" iyy="0.019099069" iyz="0.000000000" izz="0.008189704"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/foldchair_102255_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/foldchair_102255_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.007925004 0.163360724 0.010113932" rpy="0 0 0"/>
      <mass value="0.032870864"/>
      <inertia ixx="0.001816991" ixy="0.000000000" ixz="0.000000000" iyy="0.001436736" iyz="0.000000000" izz="0.003211894"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="0.000000000 -0.012001708 0.007995042" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="1.000000000 0.000000000 0.000000000"/>
    <limit lower="-1.396263402" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
