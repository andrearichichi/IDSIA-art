<?xml version="1.0"?>
<robot name="storage_45135">
  <!-- Meshes come from the dataset *_rotate exports, which share the joint frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/storage_45135_base.obj"/>
      </geometry>
      <material name="steel_grey">
        <color rgba="0.70 0.70 0.72 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/storage_45135_base.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.013470023 -0.211303630 0.119331198" rpy="0 0 0"/>
      <mass value="0.075717439"/>
      <inertia ixx="0.020054628" ixy="0.000000000" ixz="0.000000000" iyy="0.023975386" iyz="0.000000000" izz="0.014292671"/>
    </inertial>
  </link>

  <link name="moving_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/storage_45135_moving.obj"/>
      </geometry>
      <material name="handle_orange">
        <color rgba="0.93 0.47 0.16 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/storage_45135_moving.obj"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.030206647 -0.516530169 0.087568440" rpy="0 0 0"/>
      <mass value="0.024282561"/>
      <inertia ixx="0.001526486" ixy="0.000000000" ixz="0.000000000" iyy="0.003292218" iyz="0.000000000" izz="0.003914181"/>
    </inertial>
  </link>

  <joint name="scissor_hinge" type="revolute">
    <origin xyz="-0.014597692 -0.382321000 0.135593923" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="moving_link"/>
    <axis xyz="0.000000000 -1.000000000 0.000000000"/>
    <limit lower="0.000000000" upper="0.000000000" effort="5.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>
